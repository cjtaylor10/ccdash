{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccdash",
  "version": "0.6.0",
  "identifier": "com.ccdash.app",
  "build": {
    "frontendDist": "ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "ccdash",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  }
}
