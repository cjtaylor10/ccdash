{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ccdash",
  "version": "0.1.0",
  "identifier": "com.ccdash.app",
  "build": {
    "frontendDist": "ui/build"
  },
  "app": {
    "windows": [
      {
        "title": "ccdash",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
